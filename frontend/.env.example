# Variables de entorno del frontend (Vite).
# Copiá este archivo a .env.local y ajustá los valores.
# El .env.local NO se versiona (está en .gitignore).

# URL base de la API del backend.
# Por defecto apunta al servidor de desarrollo local.
# En producción, cambiar a la URL pública de la API.
VITE_API_URL=http://localhost:8000/api
