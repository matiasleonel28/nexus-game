# Copiá este archivo a .env y completá los valores.
# El .env real NO se versiona (está en .gitignore).
# ⚠️  Las variables marcadas como REQUERIDAS deben estar definidas.
#     Si faltan, el servidor falla al arrancar (fail-at-startup).

# --- IGDB (metadata de juegos) --- https://dev.twitch.tv
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- IsThereAnyDeal (precios Hunter: Steam/eShop/Xbox) --- https://isthereanydeal.com/apps/new/
ITAD_API_KEY=
ITAD_COUNTRY=AR          # AR -> precios en ARS

# --- JWT / Auth --- ⚠️ REQUERIDAS en producción (generá valores únicos con: openssl rand -hex 32)
SECRET_KEY=              # Token de acceso (60 min)
REFRESH_SECRET_KEY=      # Token de refresh (7 días)
PASSWORD_RESET_SECRET_KEY=  # Token de reseteo de contraseña (15 min)

# --- JWT / configuración opcional ---
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=15

# --- Cookies ---
# COOKIE_SECURE=true     # ← Descomentar en producción (HTTPS). En dev con HTTP, dejar false.

# --- Solo desarrollo local ---
# DEV_NO_AUTH=1  -> saltea el login usando un usuario fijo "dev@local".
#                   Con esta variable, los secretos JWT tienen valores de desarrollo automáticos.
#                   Dejalo apagado (sin definir) en cualquier entorno real.
