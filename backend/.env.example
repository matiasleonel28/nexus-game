# Copiá este archivo a .env y completá los valores.
# El .env real NO se versiona (está en .gitignore).

# --- IGDB (metadata de juegos) --- https://dev.twitch.tv
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- IsThereAnyDeal (precios Hunter: Steam/eShop/Xbox) --- https://isthereanydeal.com/apps/new/
ITAD_API_KEY=
ITAD_COUNTRY=AR          # AR -> precios en ARS

# --- JWT / auth --- (tienen defaults de dev en security.py; cambialos en prod)
SECRET_KEY=dev_super_secret_key_change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Solo desarrollo local ---
# DEV_NO_AUTH=1  -> saltea el login usando un usuario fijo "dev@local".
#                   Dejalo apagado (sin definir) en cualquier entorno real.
